    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": \"# Are there distinct groups of patients based on symptoms, and do these groups differ in diabetes outcomes?\",\n",
    "   \"id\": \"3e4945eed19cc905\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
