    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"clusters = [i for i in range(2,15)]\\n\",\n",
    "    \"silhouettes = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for cluster in clusters:\\n\",\n",
    "    \"    kmeans = KMeans(n_clusters = cluster, random_state = 0)\\n\",\n",
    "    \"    label = kmeans.fit_predict(df)\\n\",\n",
    "    \"    silhouettes.append(silhouette_score(df, label))\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title(\\\"Silhouette Score\\\")\\n\",\n",
    "    \"plt.plot(clusters, silhouettes)\\n\",\n",
    "    \"plt.xlabel(\\\"Number of clusters\\\")\\n\",\n",
    "    \"plt.ylabel(\\\"Silhouette Score\\\")\\n\",\n",
    "    \"plt.tight_layout()\"\n",
