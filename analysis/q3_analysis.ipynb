    "     \"start_time\": \"2026-04-11T20:41:13.300178Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"df = pd.read_csv(\\\"../files/early_diabetes_data_cleaned.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"target = df['class']\\n\",\n",
    "    \"features = df.drop('class', axis = 1).copy()\\n\"\n",
    "   ],\n",
